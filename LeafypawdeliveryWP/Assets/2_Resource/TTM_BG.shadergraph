{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "3ec2cf5750454963b50fda742185bbb1",
    "m_Group": {
        "m_Id": "a8168793d8f64d8f8e48443ff2e300b2"
    },
    "m_Name": "AdjustHSL (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -3372.0,
            "y": -1297.999755859375,
            "width": 214.0,
            "height": 165.9998779296875
        }
    },
    "m_Slots": [
        {
            "m_Id": "6c012be90a36497d83af502954f68bc6"
        },
        {
            "m_Id": "e1e1b63d60fa4ce387f1e2901563ff2a"
        },
        {
            "m_Id": "e360c799559d4fae9c6f4b19658b5353"
        },
        {
            "m_Id": "ed96588c80fb42418e1bd304cceea77d"
        },
        {
            "m_Id": "c0303e413884461194a417f2853b4752"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "AdjustHSL",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float3 c = InColor.rgb;\r\n\r\n// -------- RGB -> HSV --------\r\nfloat4 K1 = float4(0.0, -1.0 / 3.0, 2.0 / 3.0, -1.0);\r\nfloat4 p = c.g < c.b ? float4(c.bg, K1.wz) : float4(c.gb, K1.xy);\r\nfloat4 q = c.r < p.x ? float4(p.xyw, c.r) : float4(c.r, p.yzx);\r\n\r\nfloat d = q.x - min(q.w, q.y);\r\nfloat e = 1e-10;\r\n\r\nfloat3 hsv;\r\nhsv.x = abs(q.z + (q.w - q.y) / (6.0 * d + e)); // H\r\nhsv.y = d / (q.x + e);                           // S\r\nhsv.z = q.x;                                     // V\r\n\r\n// -------- H/S/L 조정 --------\r\nhsv.x = frac(hsv.x + HueShift);          // Hue 회전\r\nhsv.y = saturate(hsv.y * Saturation);    // Saturation 스케일\r\nhsv.z = saturate(hsv.z * Lightness);     // 밝기 스케일\r\n\r\n// -------- HSV -> RGB --------\r\nfloat4 K2 = float4(1.0, 2.0 / 3.0, 1.0 / 3.0, 3.0);\r\nfloat3 p2 = abs(frac(hsv.xxx + K2.xyz) * 6.0 - K2.www);\r\nfloat3 rgb = hsv.z * lerp(K2.xxx, saturate(p2 - K2.xxx), hsv.y);\r\n\r\n// 최종 출력\r\nOutColor = float4(rgb, InColor.a);\r\n"
}

